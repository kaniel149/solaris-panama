# Solaris Panama platform environment template
# Copy to .env.local for local browser/dev values. Keep real secrets out of git.

# Browser/client
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_POSTHOG_KEY=phc_xxxxx
VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_CLARITY_ID=
VITE_PUBLIC_WHATSAPP_PHONE=50765831822

# Server-side API routes
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
CRON_SECRET=random-long-secret
AUTOMATION_SECRET=random-long-secret
WHATSAPP_SYNC_SECRET=random-long-secret

# Meta Lead Ads + CAPI
META_WEBHOOK_VERIFY_TOKEN=random-webhook-token
META_APP_SECRET=your-meta-app-secret
META_PAGE_ID=1090136187506938
META_PAGE_ACCESS_TOKEN=your-long-lived-page-token
META_PIXEL_ID=928138543031656
META_CAPI_TOKEN=your-meta-capi-token
META_CAPI_TEST_CODE=

# Google Lead Forms + Offline Conversions
GOOGLE_LEADS_WEBHOOK_KEY=random-google-leads-key
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-oauth-client-id
GOOGLE_ADS_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
GOOGLE_ADS_CUSTOMER_ID=2386814319
GOOGLE_ADS_LOGIN_CUSTOMER_ID=3253159193
GOOGLE_ADS_CONVERSION_ACTION_ID=your-conversion-action-id

# Roof scanner APIs
GOOGLE_SOLAR_API_KEY=your-google-solar-api-key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
NREL_API_KEY=your-nrel-api-key

# Bridge watchdog fallback channels. Configure at least one.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WA_FROM=
META_WA_TOKEN=
META_WA_PHONE_ID=
RESEND_API_KEY=
