{
  "rewrites": [
    { "source": "/", "destination": "/home.html" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/towns/:path*", "destination": "/towns/:path*" },
    { "source": "/blog/:path*", "destination": "/blog/:path*" },
    { "source": "/nosotros.html", "destination": "/nosotros.html" },
    { "source": "/servicios.html", "destination": "/servicios.html" },
    { "source": "/contacto.html", "destination": "/contacto.html" },
    { "source": "/politica-de-privacidad.html", "destination": "/politica-de-privacidad.html" },
    { "source": "/terminos-de-servicio.html", "destination": "/terminos-de-servicio.html" },
    { "source": "/ads-creatives/:path*", "destination": "/ads-creatives/:path*" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
